# Conexión a TiDB Cloud (Starter/Serverless)
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=3306
DB_USER=<prefijo>.root
DB_PASSWORD=<tu_password>
DB_NAME=bikeStore

# Secreto para firmar los JWT (usa uno largo y aleatorio, ej: openssl rand -hex 32)
JWT_SECRET=<genera_un_secreto_largo_y_aleatorio>

# Puerto donde corre la API
PORT=3600

# SMTP para el correo de restablecimiento de contraseña
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<tu_correo@gmail.com>
EMAIL_PASS=<contraseña_de_aplicacion>

# URL base del frontend, usada para armar el enlace de restablecimiento de contraseña
FRONTEND_URL=http://localhost:5500
